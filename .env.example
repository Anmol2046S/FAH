# ═══════════════════════════════════════════════
#  FAH AI — Environment Variables
#  Copy to .env and fill in your values
# ═══════════════════════════════════════════════

# Server
NODE_ENV=development
PORT=8080

# Firebase / Firestore
FIREBASE_PROJECT_ID=your-gcp-project-id
# On Cloud Run, use Application Default Credentials (no key file needed).
# For local dev, point to your service account key:
# GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# CORS — comma-separated list of allowed frontend origins
# Use * for development, restrict in production
ALLOWED_ORIGINS=http://localhost:3000,https://your-frontend-domain.com

# (Future) Vertex AI / Gemini
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
VERTEX_AI_LOCATION=us-central1
GEMINI_MODEL=gemini-1.5-pro
